# Copy this file to .env and fill in your values
# NEVER commit .env to git — it's in .gitignore

ANTHROPIC_API_KEY=your_api_key_here

# Set to "false" when you're ready to actually send emails
# Defaults to "true" (dry-run) for safety
DRY_RUN=true

# Optional: SMTP config for live sending (not needed in dry-run)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@company.com
# SMTP_PASS=your_app_password
# SMTP_FROM=accounts@yourcompany.com
